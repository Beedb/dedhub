// ============================================
// 3. FUNÇÕES AUXILIARES
// ============================================
function getLevelName(level) {
  const map = { beginner: 'Iniciante', intermediate: 'Intermediário', advanced: 'Avançado', forum: 'Dúvida' };
  return map[level] || level;
}

function getTypeName(type) {
  const map = { docs: 'Documentação', article: 'Artigo', course: 'Curso', forum: 'Fórum', 'forum-content': 'Discussão', tool: 'Ferramenta' };
  return map[type] || type;
}

// ============================================
// 4. RENDERIZAÇÃO DOS CARDS (com créditos)
// ============================================
function renderCards(containerId, pageName = null, filters = { level: 'all', type: 'all', lang: 'all' }) {
  let filtered = [...recursos];
  
  if (pageName) {
    filtered = filtered.filter(r => r.page === pageName);
  }
  
  if (filters.level !== 'all') {
    filtered = filtered.filter(r => r.level === filters.level);
  }
  if (filters.type !== 'all') {
    filtered = filtered.filter(r => r.type === filters.type);
  }
  if (filters.lang !== 'all') {
    filtered = filtered.filter(r => r.lang === filters.lang);
  }
  
  const container = document.getElementById(containerId);
  if (!container) return;
  
  if (pageName === 'duvidas') {
    container.innerHTML = filtered.map(r => `
      <div class="faq-item">
        <div class="faq-question"><i class="fas fa-question-circle" style="color: var(--secondary);"></i> <a href="${r.url}" target="_blank" rel="noopener">${r.title}</a></div>
        <div class="card-badges">
          <span class="badge badge-level-${r.level}"><i class="fas fa-chart-line"></i> ${getLevelName(r.level)}</span>
          <span class="badge badge-type"><i class="fas fa-file-alt"></i> ${getTypeName(r.type)}</span>
          <span class="badge badge-lang"><i class="fas fa-globe"></i> ${r.lang === 'pt' ? '🇧🇷 Português' : '🇺🇸 Inglês'}</span>
          <span class="badge badge-free"><i class="fas fa-gem"></i> Gratuito</span>
        </div>
        <div class="faq-answer">${r.desc}</div>
        <div class="card-footnote"><i class="fas fa-link"></i> Fonte: ${r.site}</div>
      </div>
    `).join('');
  } else {
    container.innerHTML = filtered.map(r => `
      <div class="card">
        <div class="card-badges">
          <span class="badge badge-level-${r.level}"><i class="fas fa-chart-line"></i> ${getLevelName(r.level)}</span>
          <span class="badge badge-type"><i class="fas fa-file-alt"></i> ${getTypeName(r.type)}</span>
          <span class="badge badge-lang"><i class="fas fa-globe"></i> ${r.lang === 'pt' ? '🇧🇷 Português' : '🇺🇸 Inglês'}</span>
          <span class="badge badge-free"><i class="fas fa-gem"></i> Gratuito</span>
          ${r.title.includes('DevCursosBrasil') || r.credit ? '<span class="badge badge-credit"><i class="fas fa-star"></i> Destaque</span>' : ''}
        </div>
        <div class="card-title"><a href="${r.url}" target="_blank" rel="noopener">${r.title}</a></div>
        <div class="card-meta"><i class="fas fa-building"></i> ${r.site}</div>
        <div class="card-desc">${r.desc}</div>
        <div class="card-footnote"><i class="fas fa-tag"></i> ${getTypeName(r.type)} • ${getLevelName(r.level)}</div>
        ${r.credit ? `
        <div class="credit-highlight">
          <i class="fab fa-github"></i> Mantido por 
          <a href="${r.credit}" target="_blank">${r.credit.replace('https://github.com/', '')}</a>
        </div>` : ''}
      </div>
    `).join('');
  }
}

// ============================================
// 4.1 FUNÇÃO PARA EMBARALHAR DESTAQUES
// ============================================
function shuffleArray(array) {
  const shuffled = [...array];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled;
}

function renderHomeWithRandomHighlights() {
  const homeRecursos = recursos.filter(r => r.page === "home");
  const shuffled = shuffleArray(homeRecursos);
  
  // Pega 4 recursos aleatórios (ou todos se houver menos de 4)
  const destaques = shuffled.slice(0, 4);
  
  const container = document.getElementById('destaques-grid');
  if (!container) return;
  
  container.innerHTML = destaques.map(r => `
    <div class="card">
      <div class="card-badges">
        <span class="badge badge-level-${r.level}"><i class="fas fa-chart-line"></i> ${getLevelName(r.level)}</span>
        <span class="badge badge-type"><i class="fas fa-file-alt"></i> ${getTypeName(r.type)}</span>
        <span class="badge badge-lang"><i class="fas fa-globe"></i> ${r.lang === 'pt' ? '🇧🇷 Português' : '🇺🇸 Inglês'}</span>
        <span class="badge badge-free"><i class="fas fa-gem"></i> Gratuito</span>
        ${r.title.includes('DevCursosBrasil') || r.credit ? '<span class="badge badge-credit"><i class="fas fa-star"></i> Destaque</span>' : ''}
      </div>
      <div class="card-title"><a href="${r.url}" target="_blank" rel="noopener">${r.title}</a></div>
      <div class="card-meta"><i class="fas fa-building"></i> ${r.site}</div>
      <div class="card-desc">${r.desc}</div>
      <div class="card-footnote">
        <i class="fas fa-tag"></i> ${getTypeName(r.type)} • ${getLevelName(r.level)}
        <span style="float: right;"><i class="fas fa-dice"></i> Aleatório</span>
      </div>
      ${r.credit ? `
      <div class="credit-highlight">
        <i class="fab fa-github"></i> Mantido por 
        <a href="${r.credit}" target="_blank">${r.credit.replace('https://github.com/', '')}</a>
      </div>` : ''}
    </div>
  `).join('');
  
  // Remove o contador antigo se existir
  const oldCounter = document.querySelector('#destaques-grid + div');
  if (oldCounter) oldCounter.remove();
  
  // Adiciona contador de recursos
  const totalHomeRecursos = homeRecursos.length;
  const counterHTML = `
    <div style="text-align: center; margin-top: 16px; font-size: 12px; color: var(--text-light);">
      <i class="fas fa-sync-alt"></i> Mostrando ${destaques.length} de ${totalHomeRecursos} recursos em destaque • 
      <a href="#" onclick="recarregarDestaques(); return false;" style="color: var(--primary); font-weight: 600;">
        <i class="fas fa-dice"></i> Sortear novamente
      </a>
    </div>
  `;
  
  container.insertAdjacentHTML('afterend', counterHTML);
}

// Função global para recarregar destaques
function recarregarDestaques() {
  // Remove o contador antigo se existir
  const oldCounter = document.querySelector('#destaques-grid + div');
  if (oldCounter) oldCounter.remove();
  
  // Renderiza novos destaques
  renderHomeWithRandomHighlights();
  
  // Pequena animação de feedback
  const grid = document.getElementById('destaques-grid');
  grid.style.opacity = '0';
  grid.style.transition = 'opacity 0.3s ease';
  setTimeout(() => {
    grid.style.opacity = '1';
  }, 50);
}

// ============================================
// 5. FILTROS E NAVEGAÇÃO
// ============================================
let currentPage = 'home';
let currentFilters = { level: 'all', type: 'all', lang: 'all' };

function applyFiltersToCurrentPage() {
  if (currentPage === 'home') {
    renderHomeWithRandomHighlights();
  } else if (currentPage === 'html') {
    renderCards('html-grid', 'html', currentFilters);
  } else if (currentPage === 'css') {
    renderCards('css-grid', 'css', currentFilters);
  } else if (currentPage === 'ferramentas') {
    renderCards('ferramentas-grid', 'ferramentas', currentFilters);
  } else if (currentPage === 'pratica') {
    renderCards('pratica-grid', 'pratica', currentFilters);
  } else if (currentPage === 'duvidas') {
    renderCards('duvidas-grid', 'duvidas', currentFilters);
  }
}

function setupFilters() {
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.closest('[data-filter-group]');
      if (!group) return;
      
      const groupName = group.getAttribute('data-filter-group');
      const filterValue = btn.getAttribute('data-filter');
      
      if (groupName === 'level') currentFilters.level = filterValue;
      if (groupName === 'type') currentFilters.type = filterValue;
      if (groupName === 'lang') currentFilters.lang = filterValue;
      
      group.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      applyFiltersToCurrentPage();
    });
  });
  
  document.getElementById('resetFilters').addEventListener('click', () => {
    currentFilters = { level: 'all', type: 'all', lang: 'all' };
    document.querySelectorAll('.filter-btn').forEach(btn => {
      if (btn.getAttribute('data-filter') === 'all') {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
    applyFiltersToCurrentPage();
  });
}

function setupNavigation() {
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const pageId = tab.getAttribute('data-page');
      if (!pageId) return;
      
      currentPage = pageId;
      
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      
      document.querySelectorAll('.content-page').forEach(page => page.classList.remove('active'));
      document.getElementById(`page-${pageId}`).classList.add('active');
      
      applyFiltersToCurrentPage();
    });
  });
}

// ============================================
// 6. INICIALIZAÇÃO
renderHomeWithRandomHighlights();
renderCards('html-grid', 'html', currentFilters);
renderCards('css-grid', 'css', currentFilters);
renderCards('ferramentas-grid', 'ferramentas', currentFilters);
renderCards('pratica-grid', 'pratica', currentFilters);
renderCards('duvidas-grid', 'duvidas', currentFilters);
setupFilters();
setupNavigation();
initDarkMode();
</script>

